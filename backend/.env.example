# Server Configuration
SERVER_PORT=8080
GIN_MODE=debug

# Database
DATABASE_PATH=jobhaunt.db

# Google AI Studio API Key (for resume tailoring via Gemini)
GOOGLE_API_KEY=your-google-ai-studio-api-key

# LinkedIn Credentials
LINKEDIN_EMAIL=your-linkedin-email
LINKEDIN_PASSWORD=your-linkedin-password

# Scheduled Search Interval (e.g., 30m, 1h, 6h)
SCHEDULE_INTERVAL=30m

# Resume Storage
RESUME_DIR=./uploads
